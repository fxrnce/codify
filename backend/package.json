{
  "name": "codify-backend",
  "version": "1.0.0",
  "description": "Backend REST API for the Codify mobile application",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "predev": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "pretypecheck": "prisma generate",
    "typecheck": "tsc --noEmit",
    "prebuild": "prisma generate",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:render": "npm run prisma:migrate:deploy && npm start",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:test": "tsx src/scripts/test-database.ts"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "@clerk/express": "^2.1.40",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.9",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.23.1",
    "typescript": "~5.9.3"
  }
}
