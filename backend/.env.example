# Local defaults. Render supplies PORT automatically in production.
NODE_ENV=development
PORT=3000

# Use * for native-only development. For a web client, use its exact origin.
CORS_ORIGIN=*

# The publishable key is safe to expose; the secret key must remain private.
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key

# Use the hosted PostgreSQL connection string in production.
DATABASE_URL=postgresql://username:password@host/database?sslmode=verify-full
